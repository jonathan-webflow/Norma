---
---

<section class="bg-canvas">
  <div class="mx-auto max-w-container px-gutter">

    <!-- Row 1: Headline (esquerda) + Body/CTA (direita) -->
    <div class="flex flex-col md:flex-row md:justify-between pt-section gap-flow">

      <!-- Esquerda: Headline (~55% da largura) -->
      <div class="md:max-w-[55%]">
        <h1 class="font-display text-display-1 text-ink">
          Não deixe sua margem refém do governo nem dos fornecedores
        </h1>
      </div>

      <!-- Direita: Body + CTA (~40%), alinhado ao fundo -->
      <div class="flex flex-col justify-end gap-flow md:max-w-[40%]">
        <p class="font-sans text-body-xl text-ink-muted">
          Concilie a apuração do fisco, monitore e recolha os impostos dos fornecedores para garantir seus créditos e reduzir risco de autuação
        </p>

        <div>
          <a
            href="#"
            class="inline-flex items-center justify-center bg-brand-dark text-ink-inverse font-display text-[1rem] tracking-[0.125em] whitespace-nowrap px-6 h-12 rounded-md"
            data-char-btn
          >
            Conheça a solução
          </a>
        </div>
      </div>
    </div>

    <!-- Row 2: Imagem dentro do box -->
    <div class="relative mt-section mb-8 rounded-xl overflow-hidden h-[clamp(16rem,8rem+30vw,32.5rem)] bg-surface">
      <img
        src="/images/hero-bg.jpg"
        alt=""
        width="1280"
        height="520"
        class="w-full h-full object-cover"
        loading="eager"
      />

    </div>

  </div>
</section>
