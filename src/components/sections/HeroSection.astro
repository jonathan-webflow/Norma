---
import { Picture } from 'astro:assets';
import heroDashboard from '../../assets/images/hero-dashboard.png';
---

<section class="bg-canvas">
  <div class="mx-auto max-w-container px-gutter">

    <!-- Row 1: Headline (esquerda) + Body/CTA (direita) -->
    <div class="flex flex-col md:flex-row md:justify-between pt-section gap-flow">

      <!-- Esquerda: Headline (~55% da largura) -->
      <div class="md:max-w-[55%]">
        <h1 class="font-display text-display-1 text-ink" data-reveal="heading">
          Não deixe sua margem refém do governo nem dos fornecedores
        </h1>
      </div>

      <!-- Direita: Body + CTA (~40%), alinhado ao fundo -->
      <div class="flex flex-col justify-end gap-flow md:max-w-[40%]" data-reveal="block">
        <p class="font-sans text-body-base md:text-body-xl text-ink-muted">
          Concilie a apuração do fisco, monitore e recolha os impostos dos fornecedores para garantir seus créditos e reduzir risco de autuação
        </p>

        <div>
          <a
            href="#"
            class="inline-flex items-center justify-center bg-brand-dark text-ink-inverse font-display text-[1rem] tracking-[0.125em] whitespace-nowrap px-6 h-12 rounded-md"
            data-char-btn
          >
            Conheça a solução
          </a>
        </div>
      </div>
    </div>

    <!-- Row 2: Imagem dentro do box -->
    <div class="relative mt-section mb-8 rounded-xl overflow-hidden aspect-4/3 md:aspect-59/31 bg-surface">
      <Picture
        src={heroDashboard}
        alt="Painel da Norma com a apuração da CBS conciliada entre Fisco e ERP"
        formats={['avif', 'webp']}
        fallbackFormat="webp"
        widths={[640, 960, 1416]}
        sizes="(min-width: 88.5rem) 1416px, 100vw"
        quality={95}
        class="w-full h-full object-cover"
        loading="eager"
      />

    </div>

  </div>
</section>
