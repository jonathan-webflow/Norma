---

<section class="bg-canvas py-section">
  <div class="mx-auto max-w-container px-gutter">
    <div class="flex flex-col items-center gap-flow">

      <!-- Título -->
      <h2 class="font-display text-display-2 text-ink text-center max-w-[46.625rem]" data-reveal="heading">
        A plataforma que coloca sua empresa no controle da Reforma.
      </h2>

      <!-- Dots + texto + cards -->
      <div class="flex flex-col items-center gap-flow w-full">

        <!-- Brand-mark dots (sticky-stack ligado ao scroll) -->
        <div class="dots" aria-hidden="true">
          <span class="dot" style="--op: 0.4;"><span class="hex"></span></span>
          <span class="dot" style="--op: 0.7;"><span class="hex"></span></span>
          <span class="dot" style="--op: 1;"><span class="hex"></span></span>
          <span class="dot dot--focal" style="--op: 1;"><span class="hex"></span></span>
        </div>

        <!-- Texto + cards -->
        <div class="flex flex-col items-center gap-12 w-full">
          <p class="font-sans text-[clamp(1.125rem,0.9rem+1vw,1.5rem)] leading-[1.4] text-ink text-center max-w-[42.25rem]" data-reveal="block">
            A Norma transforma a complexidade da Reforma Tributária em uma operação auditável, conciliada e controlada.
          </p>

          <div class="flex flex-col md:flex-row gap-[clamp(1rem,0.5rem+2vw,1.5rem)] w-full max-w-[66.0625rem]" data-reveal="cards">
            {FEATURES.map((f) => (
              <div class="flex-1 flex flex-col items-center justify-center gap-4 p-6 rounded-md bg-[#f0f0ea] text-brand">
                <svg
                  width="40"
                  height="40"
                  viewBox="0 0 40 40"
                  fill="none"
                  aria-hidden="true"
                  class="shrink-0"
                >
                  <path d={f.path} fill="currentColor" />
                </svg>
                <p class="font-sans text-body-xl text-ink text-center">{f.label}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  /* Hexágono brand mark (flat-top), 2.052 × 1.466rem (32.83 × 23.45px) — Figma */
  .hex {
    display: block;
    width: 2.052rem;
    height: 1.466rem;
    background-color: var(--color-gold);
    clip-path: polygon(20% 0%, 80% 0%, 100% 50%, 80% 100%, 20% 100%, 0% 50%);
  }

  /* Coluna alta: os dots começam espalhados e, no scroll, grudam e se empilham */
  .dots {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    height: clamp(32.5rem, 70vh, 47.5rem);
  }

  /* Cada dot é uma caixa idêntica (124px) que gruda na MESMA linha (top:40vh).
     Como todas têm o mesmo tamanho e top, ao empilhar ficam concêntricas:
     os hexágonos translúcidos convergem para o centro do anel focal. */
  .dot {
    position: sticky;
    top: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 7.75rem;
    height: 7.75rem;
    opacity: var(--op, 1);
  }

  /* Anel focal: a própria caixa vira o círculo verde, com hexágono no centro */
  .dot--focal {
    border: 1.1rem solid var(--color-brand);
    border-radius: 9999px;
    background-color: transparent;
  }

  /* Sem stick em reduced-motion: dots ficam empilhados estáticos (look do Figma) */
  @media (prefers-reduced-motion: reduce) {
    .dots {
      height: auto;
      gap: 3.875rem;
    }
    .dot {
      position: static;
      width: auto;
      height: auto;
    }
    .dot--focal {
      width: 7.75rem;
      height: 7.75rem;
    }
  }
</style>

