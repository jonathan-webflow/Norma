---
// Seção "Risco da Reforma" (Figma 867:883): visual à esquerda + conteúdo à direita
// (heading, subtítulo, 3 pontos com ícone, CTA). Bloco estático, padrão de layout do projeto.
import { Image } from 'astro:assets';
import riscoReforma from '../../assets/images/tiles/risco-reforma.png';

const HEADING = 'O maior risco da Reforma\nestá nos próximos meses';
const POINTS = [
  {
    icon: '/images/tiles/icons/risco-regras.svg',
    text: 'Crédito, apuração, pagamentos e contestação passam a operar sob novas regras enquanto a transição ainda está em andamento.',
  },
  {
    icon: '/images/tiles/icons/risco-controle.svg',
    text: 'As empresas que se prepararem cedo terão mais controle sobre crédito, caixa e conformidade.',
  },
  {
    icon: '/images/tiles/icons/risco-divergencia.svg',
    text: 'As demais passarão a reagir a divergências depois que elas já tiverem gerado impacto financeiro.',
  },
] as const;
---

<section class="bg-canvas py-section">
  <div class="mx-auto max-w-container px-gutter">
    <div class="flex flex-col lg:flex-row lg:items-stretch gap-[clamp(2rem,1rem+4vw,5rem)]">

      <!-- Esquerda: visual -->
      <div class="w-full lg:w-[min(42vw,39.75rem)] shrink-0">
        <Image
          src={riscoReforma}
          alt="Representação abstrata da transição da Reforma Tributária"
          widths={[400, 636]}
          sizes="(min-width: 64rem) 39.75rem, 100vw"
          format="webp"
          quality={90}
          class="w-full h-full object-cover rounded-xl aspect-[636/680] lg:aspect-auto"
          loading="lazy"
          decoding="async"
        />
      </div>

      <!-- Direita: conteúdo -->
      <div class="flex-1 flex flex-col gap-[clamp(2.5rem,1.5rem+3vw,4rem)] lg:pb-6">

        <div class="flex flex-col gap-3">
          <h2 class="font-display text-display-2 text-ink leading-[1.2] tracking-[-0.01em] whitespace-normal lg:whitespace-pre-line lg:[text-wrap:initial]">
            {HEADING}
          </h2>
          <p class="font-sans text-body-xl text-ink leading-[1.6]">
            As mudanças começam a impactar crédito, caixa e conformidade muito antes da conclusão da transição.
          </p>
        </div>

        <div class="flex flex-col gap-10">
          <ul class="flex flex-col">
            {POINTS.map((p, i) => (
              <li class={`flex items-center gap-4 pt-8 ${i > 0 ? 'mt-8 border-t border-[#ededed]' : ''}`}>
                <span class="shrink-0 flex items-center justify-center size-8 rounded-[0.333rem] bg-[#f0f0ea]">
                  <img src={p.icon} alt="" width="21" height="21" class="w-[1.333rem] h-[1.333rem]" aria-hidden="true" />
                </span>
                <p class="flex-1 font-sans text-body-base text-ink leading-[1.6]">{p.text}</p>
              </li>
            ))}
          </ul>

          <a
            href="#contato"
            class="inline-flex self-start items-center justify-center bg-brand-dark text-ink-inverse font-display text-[1rem] tracking-[0.125em] whitespace-nowrap px-6 h-12 rounded-md"
            data-char-btn
          >
            Solicitar diagnóstico
          </a>
        </div>

      </div>
    </div>
  </div>
</section>
