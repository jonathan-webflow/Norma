---
// Fonte única das redes sociais — usada por ambas as variantes do Footer.
// Mudanças de URL/ícone aqui refletem em todos os lugares que consomem o parcial.
import { WHATSAPP_URL } from '../../config/links';

interface Props {
  /** Classe extra para o container (ex.: alinhamento na variante simple). */
  class?: string;
}

const { class: className } = Astro.props;

const SOCIAL_LINKS = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/company/consulteanorma/', external: true },
  { label: 'WhatsApp', href: WHATSAPP_URL, external: true },
  { label: 'Instagram', href: 'https://www.instagram.com/consulteanorma/', external: true },
  { label: 'Enviar e-mail', href: 'mailto:contato@sosreforma.com.br?subject=Contato%20Website', external: false },
] as const;

const [linkedinLink, whatsappLink, instagramLink, emailLink] = SOCIAL_LINKS;
---

<div class:list={['flex items-center gap-[1.125rem] -m-2', className]}>
  <a
    href={linkedinLink.href}
    aria-label={linkedinLink.label}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center w-12 h-12 text-ink-inverse/70 hover:text-ink-inverse transition-colors duration-150"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <rect x="2" y="9" width="4" height="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="1.5"/>
    </svg>
  </a>

  <a
    href={whatsappLink.href}
    aria-label={whatsappLink.label}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center w-12 h-12 text-ink-inverse/70 hover:text-ink-inverse transition-colors duration-150"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>

  <a
    href={instagramLink.href}
    aria-label={instagramLink.label}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center justify-center w-12 h-12 text-ink-inverse/70 hover:text-ink-inverse transition-colors duration-150"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="1.5"/>
    </svg>
  </a>

  <a
    href={emailLink.href}
    aria-label={emailLink.label}
    class="inline-flex items-center justify-center w-12 h-12 text-ink-inverse/70 hover:text-ink-inverse transition-colors duration-150"
  >
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="m2 7 10 7 10-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</div>
