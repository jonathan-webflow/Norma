---
import SocialLinks from './SocialLinks.astro';

interface Props {
  /** 'full' = footer completo com colunas de navegação; 'simple' = landing enxuta. */
  variant?: 'full' | 'simple';
}

const { variant = 'full' } = Astro.props;

const NAV_COLUMNS = [
  {
    title: 'Produtos',
    links: [
      { label: 'Produto 1', href: '#' },
      { label: 'Produto 2', href: '#' },
      { label: 'Produto 3', href: '#' },
    ],
  },
  {
    title: 'Recursos',
    links: [
      { label: 'Blog', href: '#' },
      { label: 'Suporte', href: '#' },
      { label: 'Clientes', href: '#' },
    ],
  },
  {
    title: 'Institucional',
    links: [
      { label: 'Sobre', href: '#' },
      { label: 'Newsroom', href: '#' },
      { label: 'Trabalhe conosco', href: '#' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Termos de Uso', href: '#' },
      { label: 'Política de Privacidade', href: '#' },
    ],
  },
] as const;
---

<!--
  Scroll spacer: reserva espaço no documento para o footer ter altura no scroll.
  --fh = única fonte de verdade para a altura do footer.
  O conteúdo fica em position:fixed (atrás do <main z-[1]>), revelado conforme o main sobe.
-->
<footer
  data-footer-spacer
  class="relative overflow-hidden"
  style="--fh: min(100svh, 50rem); height: var(--fh);"
>

  <!-- Conteúdo: fixo ao bottom; altura definida pelo próprio conteúdo (medida via JS → --fh) -->
  <div
    data-footer-inner
    class="fixed bottom-0 left-0 right-0 overflow-hidden bg-brand"
  >
    <div class="mx-auto max-w-container px-gutter">

      {variant === 'simple' && (
        <div class="flex flex-col gap-[clamp(4rem,2rem+8vw,8.25rem)] pt-20 pb-10">
          <div class="flex flex-col md:flex-row md:items-center gap-12">
            <img
              src="/images/norma-logo-light.svg"
              alt="Norma"
              width="170"
              height="27"
              loading="eager"
              class="shrink-0"
            />
            <p class="flex-1 font-display text-[clamp(1.25rem,1rem+1vw,1.5rem)] leading-tight text-ink-inverse/70">
              Na dúvida, consulte a Norma.
            </p>
            <SocialLinks class="shrink-0 md:justify-end" />
          </div>
          <div class="border-t border-ink-inverse/20 pt-12">
            <p class="font-sans text-body-sm text-ink-inverse/70">
              CNPJ: 54.782.822/0001-09 | Razão Social: SIGMA LABS TECNOLOGIA DA INFORMACAO LTDA | Endereço: Alameda Rio Claro, 241 — São Paulo, SP, 01332-010
            </p>
          </div>
        </div>
      )}

      {variant === 'full' && (
        <div>
          <div class="flex flex-col md:flex-row pt-section pb-[clamp(2rem,1rem+3vw,3rem)] gap-flow lg:gap-[8.25rem]">
            <div class="flex flex-col gap-12 shrink-0">
              <img
                src="/images/norma-logo-light.svg"
                alt="Norma"
                width="170"
                height="27"
                loading="eager"
              />
              <p class="font-display text-[clamp(1.25rem,1rem+1vw,1.5rem)] leading-tight text-ink-inverse/70 max-w-[12.5rem]">
                Na dúvida, consulte a Norma.
              </p>
              <SocialLinks />
            </div>
            <nav aria-label="Rodapé" class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4 flex-1">
              {NAV_COLUMNS.map((col) => (
                <div class="flex flex-col gap-5">
                  <h3 class="font-display text-body-base uppercase tracking-[0.047em] text-ink-inverse/64">
                    {col.title}
                  </h3>
                  <ul class="flex flex-col gap-1">
                    {col.links.map((link) => (
                      <li>
                        <a
                          href={link.href}
                          class="font-sans text-body-base text-ink-inverse/88 hover:text-ink-inverse transition-colors duration-150"
                        >
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </nav>
          </div>
          <div class="border-t border-ink-inverse/20"></div>
          <div class="pt-12 pb-10">
            <p class="font-sans text-body-sm text-ink-inverse/70">
              CNPJ: 54.782.822/0001-09 | Razão Social: SIGMA LABS TECNOLOGIA DA INFORMACAO LTDA | Endereço: Alameda Rio Claro, 241 — São Paulo, SP, 01332-010
            </p>
          </div>
        </div>
      )}

    </div>
  </div>
</footer>

<script>
  // Sincroniza a altura do spacer (--fh) com a altura real do conteúdo fixo.
  // Garante que o footer ocupe exatamente o conteúdo em qualquer largura — sem
  // espaço vazio no desktop nem corte no mobile. Reage a resize/reflow de fonte.
  const inner = document.querySelector<HTMLElement>('[data-footer-inner]');
  const spacer = document.querySelector<HTMLElement>('[data-footer-spacer]');

  if (inner && spacer) {
    const sync = () => spacer.style.setProperty('--fh', `${inner.offsetHeight}px`);
    sync();
    new ResizeObserver(sync).observe(inner);
  }
</script>
