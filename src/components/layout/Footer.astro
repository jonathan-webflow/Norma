---
const NAV_COLUMNS = [
  {
    title: 'Produtos',
    links: [
      { label: 'Produto 1', href: '#' },
      { label: 'Produto 2', href: '#' },
      { label: 'Produto 3', href: '#' },
    ],
  },
  {
    title: 'Recursos',
    links: [
      { label: 'Blog', href: '#' },
      { label: 'Suporte', href: '#' },
      { label: 'Clientes', href: '#' },
    ],
  },
  {
    title: 'Institucional',
    links: [
      { label: 'Sobre', href: '#' },
      { label: 'Newsroom', href: '#' },
      { label: 'Trabalhe conosco', href: '#' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Termos de Uso', href: '#' },
      { label: 'Política de Privacidade', href: '#' },
    ],
  },
] as const;
---

<footer class="bg-brand">
  <div class="mx-auto max-w-container px-gutter">

    <!-- Upper section: logo col + nav columns -->
    <div class="flex flex-col md:flex-row pt-section pb-[clamp(2rem,1rem+3vw,3rem)] gap-flow lg:gap-[8.25rem]">

      <!-- Left: logo + tagline + social icons -->
      <div class="flex flex-col gap-12 shrink-0">

        <img
          src="/images/norma-logo-light.svg"
          alt="Norma"
          width="170"
          height="27"
          loading="eager"
        />

        <p class="font-display text-[clamp(1.25rem,1rem+1vw,1.5rem)] leading-tight text-ink-inverse/70 max-w-[12.5rem]">
          Na dúvida, consulte a Norma.
        </p>

        <div class="flex items-center gap-[1.125rem] -m-2">
          <a href="#" aria-label="LinkedIn" class="inline-flex items-center justify-center w-12 h-12 text-ink-inverse/70 hover:text-ink-inverse transition-colors duration-150">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <rect x="2" y="9" width="4" height="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="4" cy="4" r="2" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </a>

          <a href="#" aria-label="WhatsApp" class="inline-flex items-center justify-center w-12 h-12 text-ink-inverse/70 hover:text-ink-inverse transition-colors duration-150">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <a href="#" aria-label="Instagram" class="inline-flex items-center justify-center w-12 h-12 text-ink-inverse/70 hover:text-ink-inverse transition-colors duration-150">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </a>

          <a href="#" aria-label="Facebook" class="inline-flex items-center justify-center w-12 h-12 text-ink-inverse/70 hover:text-ink-inverse transition-colors duration-150">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: 4 nav columns -->
      <nav aria-label="Rodapé" class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4 flex-1">
        {NAV_COLUMNS.map((col) => (
          <div class="flex flex-col gap-5">
            <h3 class="font-display text-body-base uppercase tracking-[0.047em] text-ink-inverse/64">
              {col.title}
            </h3>
            <ul class="flex flex-col gap-1">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="font-sans text-body-base text-ink-inverse/88 hover:text-ink-inverse transition-colors duration-150"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </div>

    <!-- Divider -->
    <div class="border-t border-ink-inverse/20"></div>

    <!-- Legal info -->
    <div class="pt-12 pb-10">
      <p class="font-sans text-body-sm text-ink-inverse/70">
        CNPJ: 54.782.822/0001-09 | Razão Social: SIGMA LABS TECNOLOGIA DA INFORMACAO LTDA | Endereço: Alameda Rio Claro, 241 — São Paulo, SP, 01332-010
      </p>
    </div>

  </div>
</footer>
