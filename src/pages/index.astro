---
import Layout from '../layouts/Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import MarqueeSection from '../components/sections/MarqueeSection.astro';
import DotsAnimation from '../components/sections/DotsAnimation.astro';
import IntegrationsSection from '../components/sections/IntegrationsSection.astro';
import RiskSection from '../components/sections/RiskSection.astro';
import StickyFeatures from '../components/sections/StickyFeatures.astro';
import MapSection from '../components/sections/MapSection.astro';
---

<Layout title="Norma" description="Não deixe sua margem refém do governo nem dos fornecedores">
  <Header />

  <main>
    <HeroSection />
    <MarqueeSection />
    <DotsAnimation />
    <IntegrationsSection />
    <RiskSection />
    <StickyFeatures />
    <MapSection />
  </main>

  <Footer />
</Layout>
