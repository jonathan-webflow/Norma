---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = 'Concilie a apuração do fisco, monitore e recolha os impostos dos fornecedores para garantir seus créditos e reduzir risco de autuação.',
  ogImage = '/OpenGraph-Img.png',
  canonicalUrl,
} = Astro.props;

const siteUrl = Astro.url.origin;
const canonical = canonicalUrl ?? Astro.url.href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
const ogTitle = `${title} — Norma`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- Canonical -->
    <link rel="canonical" href={canonical} />

    <!-- SEO básico -->
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Norma" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={description} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicon — adapta ao tema do sistema (light/dark) -->
    <link rel="icon" href="/favicon-light.svg" type="image/svg+xml" media="(prefers-color-scheme: light)" />
    <link rel="icon" href="/favicon-dark.svg" type="image/svg+xml" media="(prefers-color-scheme: dark)" />

    <meta name="generator" content={Astro.generator} />
    <title>{ogTitle}</title>
    <!-- Google Fonts: Stack Sans Headline (headings) + Inter (sans) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Stack+Sans+Headline:wght@300;400&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <script>
      function initCharStagger() {
        document.querySelectorAll<HTMLElement>('[data-char-btn]:not([data-char-init])').forEach((btn) => {
          btn.dataset.charInit = '1';
          const text = btn.textContent?.trim() ?? '';
          btn.innerHTML = '';
          const inner = document.createElement('span');
          inner.className = 'char-inner';
          [...text].forEach((char, i) => {
            const wrap = document.createElement('span');
            wrap.className = 'char-wrap';
            if (char === ' ') wrap.style.whiteSpace = 'pre';

            const top = document.createElement('span');
            top.className = 'char-top';
            top.textContent = char;
            top.style.transitionDelay = `${i * 0.01}s`;

            const bot = document.createElement('span');
            bot.className = 'char-bot';
            bot.textContent = char;
            bot.setAttribute('aria-hidden', 'true');
            bot.style.transitionDelay = `${i * 0.01}s`;

            wrap.appendChild(top);
            wrap.appendChild(bot);
            inner.appendChild(wrap);
          });
          btn.appendChild(inner);
        });
      }
      initCharStagger();
    </script>

    <!-- Smooth scroll (Lenis) — suaviza o scroll global; respeita reduced-motion -->
    <script>
      import Lenis from 'lenis';
      import 'lenis/dist/lenis.css';

      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const lenis = new Lenis({ lerp: 0.1, smoothWheel: true });
        (window as any).__lenis = lenis; // exposto p/ sincronizar o GSAP ScrollTrigger
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }
    </script>

    <!-- Reveal animations (scroll-driven blur+fade+stagger) — após Lenis para sync correto -->
    <script>
      import '../scripts/reveal-animations';
    </script>
  </body>
</html>
